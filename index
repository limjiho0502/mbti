<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🏫 학교 생활로 보는 나의 MBTI 💕</title>
    <style>
        /* 🌸 폰트 및 기본 스타일 세팅 */
        @import url('https://fonts.googleapis.com/css2?family=Gamja+Flower&family=Jua&display=swap');

        body {
            font-family: 'Gamja Flower', cursive;
            background-color: #FFF0F5; /* LavenderBlush (연분홍) */
            background-image: radial-gradient(#FFB6C1 10%, transparent 10%);
            background-size: 20px 20px;
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            box-sizing: border-box;
        }

        /* 🎀 메인 컨테이너 */
        .container {
            background-color: #ffffff;
            border: 4px solid #FF69B4; /* 핫핑크 테두리 */
            border-radius: 30px;
            padding: 30px;
            width: 100%;
            max-width: 480px;
            text-align: center;
            box-shadow: 0px 8px 16px rgba(255, 105, 180, 0.2);
        }

        /* 🌟 제목 스타일 */
        h1 {
            font-family: 'Jua', sans-serif;
            color: #FF1493;
            font-size: 2.2rem;
            margin-bottom: 10px;
            text-shadow: 2px 2px 0px #FFB6C1;
        }

        p.subtitle {
            font-size: 1.3rem;
            color: #FF69B4;
            margin-top: 0;
            margin-bottom: 25px;
        }

        /* 📸 메인 일러스트 대용 이모티콘 영역 */
        .main-emoji {
            font-size: 5rem;
            margin: 20px 0;
            animation: bounce 2s infinite;
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        /* 🎯 버튼 스타일 */
        .btn {
            font-family: 'Jua', sans-serif;
            background-color: #FF69B4;
            color: white;
            border: none;
            padding: 15px 30px;
            font-size: 1.4rem;
            border-radius: 50px;
            cursor: pointer;
            box-shadow: 0 4px 0 #C71585;
            transition: all 0.1s ease;
            width: 100%;
            margin-top: 15px;
            box-sizing: border-box;
        }

        .btn:active {
            transform: translateY(4px);
            box-shadow: none;
        }

        /* 📝 진행 상황 바 */
        .progress-container {
            width: 100%;
            background-color: #FFE4E1;
            border-radius: 20px;
            margin-bottom: 25px;
            overflow: hidden;
            border: 2px solid #FF69B4;
        }

        .progress-bar {
            width: 0%;
            height: 15px;
            background-color: #FF1493;
            transition: width 0.3s ease;
        }

        /* ❓ 질문 상자 */
        .question-box {
            font-size: 1.5rem;
            color: #4A4A4A;
            margin-bottom: 30px;
            font-weight: bold;
            line-height: 1.4;
            background-color: #FFF5F5;
            padding: 20px;
            border-radius: 20px;
            border: 2px dashed #FFB6C1;
        }

        /* 💖 선택지 버튼 전용 */
        .answer-btn {
            font-family: 'Gamja Flower', cursive;
            background-color: #FFF;
            color: #FF1493;
            border: 3px solid #FFB6C1;
            padding: 15px 20px;
            font-size: 1.3rem;
            border-radius: 20px;
            cursor: pointer;
            margin-bottom: 15px;
            width: 100%;
            text-align: left;
            box-sizing: border-box;
            transition: all 0.2s;
            display: flex;
            align-items: center;
        }

        .answer-btn:hover {
            background-color: #FFE4E1;
            border-color: #FF69B4;
            transform: scale(1.02);
        }

        .answer-btn span {
            margin-right: 10px;
            font-size: 1.6rem;
        }

        /* 🏆 결과창 스타일 */
        .result-title {
            font-family: 'Jua', sans-serif;
            font-size: 2.5rem;
            color: #FF1493;
            margin: 15px 0;
        }

        .result-desc {
            font-size: 1.3rem;
            color: #555;
            line-height: 1.6;
            text-align: left;
            background-color: #FFF9FA;
            padding: 20px;
            border-radius: 20px;
            border: 2px solid #FFE4E1;
        }

        /* 화면 전환용 클래스 */
        .hidden {
            display: none !important;
        }
    </style>
</head>
<body>

    <div class="container">
        <!-- 🏠 시작 화면 -->
        <div id="start-screen">
            <h1>🏫 학교 생활 MBTI 💕</h1>
            <p class="subtitle">새 학기, 나는 교실에서 어떤 학생일까?</p>
            <div class="main-emoji">🎒📚✏️</div>
            <button class="btn" onclick="startTest()">테스트 시작하기! 🚀</button>
        </div>

        <!-- 📝 질문 화면 -->
        <div id="question-screen" class="hidden">
            <div class="progress-container">
                <div class="progress-bar" id="progress-bar"></div>
            </div>
            <div class="question-box" id="question">
                질문 텍스트가 들어가는 곳 🦄
            </div>
            <div id="answers">
                <!-- 선택지 버튼들이 동적으로 생성됩니다 -->
            </div>
        </div>

        <!-- 🏆 결과 화면 -->
        <div id="result-screen" class="hidden">
            <h1>✨ 나의 학교 생활 유형 ✨</h1>
            <div class="main-emoji" id="result-emoji">🥳</div>
            <div class="result-title" id="result-name">유형 이름</div>
            <div class="result-desc" id="result-desc">
                상세 설명이 들어가는 곳
            </div>
            <button class="btn" onclick="restartTest()">다시 테스트하기 🔄</button>
        </div>
    </div>

    <script>
        // 📚 질문 데이터 구성 (E/I, S/N, T/F, J/P 유형 결정)
        const questions = [
            {
                q: "새 학기 첫날! 교실에 들어섰을 때 나의 행동은?",
                a: [
                    { text: "👋 눈에 띄는 친구들에게 다가가 '안녕! 나랑 짝꿍 할래?' 말을 건넨다.", type: "E" },
                    { text: "👀 조용히 빈자리를 찾아 앉아 스마트폰을 보거나 눈치를 살핀다.", type: "I" }
                ]
            },
            {
                q: "수업 시간, 선생님이 상상력을 자극하는 질문을 하셨다! 이때 내 생각은?",
                a: [
                    { text: "💡 '만약에 진짜 교실이 하늘을 날아다니면 어떡하지?' 온갖 상상을 펼친다.", type: "N" },
                    { text: "✏️ '그냥 교과서에 나와 있는 대로 외워야겠다.' 현실적인 시험 걱정을 한다.", type: "S" }
                ]
            },
            {
                q: "친구가 시험을 망쳐서 눈물을 흘리고 있을 때, 내가 건넬 첫마디는?",
                a: [
                    { text: "🥺 '아고 속상하겠다... 속상해하지 마, 다음에 잘 보면 돼! 토닥토닥'", type: "F" },
                    { text: "🧐 '몇 번 문제 틀렸어? 다음엔 오답 노트 만들어서 같이 풀어보자!'", type: "T" }
                ]
            },
            {
                q: "수행평가 과제가 공지되었다! 과제를 대하는 나의 태도는?",
                a: [
                    { text: "📅 일주일 치 계획표를 딱 짜서 매일 조금씩 미리 끝내둔다.", type: "J" },
                    { text: "🔥 역시 과제는 전날 밤에 하는 짜릿함이지! 벼락치기로 해결한다.", type: "P" }
                ]
            }
        ];

        // 🏆 결과 데이터 구성
        const results = {
            "ENFJ": { name: "💖 교실 안의 골든리트리버 💖", emoji: "🐶", desc: "친화력 끝판왕! 반에 우울한 친구가 있으면 절대 못 지나쳐요. 선생님들의 사랑을 독차지하는 다정다감한 학급 반장 스타일!" },
            "ENFP": { name: "🌈 아이디어가 톡톡 튀는 에너자이저 🌈", emoji: "🦄", desc: "쉬는 시간마다 앞자리에 가서 수다 떠느라 바빠요! 엉뚱하고 재기발랄한 아이디어로 친구들을 항상 웃겨주는 분위기 메이커!" },
            "ENTJ": { name: "🔥 전교 1등 포스의 야망가 🔥", emoji: "🦁", desc: "조별 과제가 시작되면 자연스럽게 조장을 맡아 하드캐리해요! 계획적이고 똑 부러져서 친구들이 은근히 의지하는 멋쟁이 리더!" },
            "ENTP": { name: "🧐 말싸움 절대 안 지는 토론 대장 🧐", emoji: "🦊", desc: "선생님 말씀에 '왜요?'를 가장 많이 던지는 호기심 천국! 장난기가 넘치지만 두뇌 회전이 빨라서 은근히 공부도 잘하는 천재형!" },
            "ESFJ": { name: "🍰 모두를 챙기는 매점 요정 🍰", emoji: "🐹", desc: "반 친구들의 생일을 다 기억하고 챙겨주는 따뜻한 친구! 매점 갈 때 늘 친구들을 몰고 다니며, 리액션이 가장 좋은 친절 수호신!" },
            "ESFP": { name: "🎉 축제 무대 장악하는 핵인싸 🎉", emoji: "🐯", desc: "학교 축제나 장기자랑이 열리면 무조건 무대 위로 올라가는 주인공! 노는 걸 제일 좋아하고 에너지가 넘쳐서 심심할 틈이 없어요." },
            "ESTJ": { name: "📢 칼같이 정확한 학급 선도부장 📢", emoji: "🦅", desc: "급식 줄 서기나 청소 시간에 질서를 어지럽히는 꼴을 못 봐요! 꼼꼼하고 책임감이 강해 학급의 규칙을 지키는 든든한 버팀목!" },
            "ESTP": { name: "🏃 체육 시간만 기다리는 만능 운동꾼 🏃", emoji: "🐆", desc: "책상 앞보다는 운동장이 체질! 시원시원하고 뒤끝 없는 성격으로 남녀 불문하고 친구가 많으며, 의리가 끝내주는 스타일!" },
            "INFJ": { name: "🔮 비밀 이야기를 들어주는 힐링 상담소 🔮", emoji: "🔮", desc: "말수가 적지만 친구들의 속마음을 가장 잘 헤아려줘요. 혼자 일기 쓰거나 책 읽는 걸 좋아하며, 은은한 존재감과 깊은 내면을 가졌어요." },
            "INFP": { name: "🎨 감성 가득한 교실 속 낭만파 🎨", emoji: "🐰", desc: "교과서 구석에 아기자기한 낙서를 하거나 이어폰을 꽂고 음악 듣는 걸 좋아해요. 수줍음이 많지만 친해지면 속 깊은 다정함을 보여줘요." },
            "INTJ": { name: "🕵️ 비밀리에 전교권을 노리는 전략가 🕵️", emoji: "🦉", desc: "쉬는 시간에도 묵묵히 마이웨이를 걷는 조용한 능력자! 겉으로는 차가워 보이지만 혼자서 완벽하게 목표를 이뤄내는 알짜배기 수재 스타일!" },
            "INTP": { name: "🧪 걸어 다니는 백과사전 걸어온 AI 🧪", emoji: "🤖", desc: "관심 있는 과목만 파고드는 천재 스타일! 남들이 관심 없는 신기한 지식을 많이 알고 있으며, 조용히 혼자 생각에 잠겨있을 때가 많아요." },
            "ISFJ": { name: " Angel 교실의 보이지 않는 천사 Angel ", emoji: "👼", desc: "친구가 빌려달라는 필기구를 군말 없이 다 빌려주는 착한 심성의 소유자! 묵묵히 자기 할 일을 다 하고 남을 배려해 주는 따뜻한 영혼이에요." },
            "ISFP": { name: "🛋️ 침대와 물아일체, 눕기 장인 🛋️", emoji: "🐨", desc: "학교에 오면 기운이 없다가 집에 갈 때쯤 활발해져요! 갈등을 싫어해서 누구와도 두루두루 잘 지내며 예술적 감각이 은근히 뛰어납니다." },
            "ISTJ": { name: "📋 오차 없는 인간 플래너 📋", emoji: "🐧", desc: "교과서 필기가 가장 깔끔하고 예쁜 친구! 숙제나 준비물을 잊어버리는 법이 절대 없으며, 규칙적이고 정직한 교실의 정석 학생!" },
            "ISTP": { name: "🛹 쿨내 진동하는 효율주의 조용 보스 🛹", emoji: "🐱", desc: "최소한의 노력으로 최대의 효율을 내는 효율 천재! 평소엔 세상 귀찮아 보이지만 자기가 꽂힌 일에는 엄청난 집중력을 발휘하는 츤데레!" }
        };

        let currentIdx = 0;
        let scores = { E: 0, I: 0, S: 0, N: 0, T: 0, F: 0, J: 0, P: 0 };

        // 🚀 테스트 시작
        function startTest() {
            document.getElementById("start-screen").classList.add("hidden");
            document.getElementById("question-screen").classList.remove("hidden");
            showQuestion();
        }

        // 📝 질문 보여주기
        function showQuestion() {
            if (currentIdx >= questions.length) {
                showResult();
                return;
            }

            // 진행 바 업데이트
            const percent = (currentIdx / questions.length) * 100;
            document.getElementById("progress-bar").style.width = percent + "%";

            // 질문 및 선택지 셋팅
            const currentQ = questions[currentIdx];
            document.getElementById("question").innerHTML = `✨ Q${currentIdx + 1}. ${currentQ.q}`;
            
            const answersDiv = document.getElementById("answers");
            answersDiv.innerHTML = "";

            currentQ.a.forEach((answer, index) => {
                const btn = document.createElement("button");
                btn.className = "answer-btn";
                btn.innerHTML = `<span>${index === 0 ? '🌸' : '🍇'}</span> ${answer.text}`;
                btn.onclick = () => selectAnswer(answer.type);
                answersDiv.appendChild(btn);
            });
        }

        // 🎯 선택지 클릭 시 점수 계산
        function selectAnswer(type) {
            scores[type]++;
            currentIdx++;
            showQuestion();
        }

        // 🏆 결과 계산 및 화면 전환
        function showResult() {
            document.getElementById("question-screen").classList.add("hidden");
            document.getElementById("result-screen").classList.remove("hidden");

            // MBTI 조합하기 (점수가 더 높은 쪽 조합, 기본값 설정)
            let mbti = "";
            mbti += scores.E >= scores.I ? "E" : "I";
            mbti += scores.S >= scores.N ? "S" : "N";
            mbti += scores.T >= scores.F ? "T" : "F";
            mbti += scores.J >= scores.P ? "J" : "P";

            // 질문이 4개뿐이라 나오지 않는 세부 유형도 보정되도록 예외 방지 매핑
            const finalResult = results[mbti] || results["ENFP"]; 

            document.getElementById("result-emoji").innerText = finalResult.emoji;
            document.getElementById("result-name").innerText = finalResult.name;
            document.getElementById("result-desc").innerText = finalResult.desc;
        }

        // 🔄 다시 하기
        function restartTest() {
            currentIdx = 0;
            scores = { E: 0, I: 0, S: 0, N: 0, T: 0, F: 0, J: 0, P: 0 };
            document.getElementById("result-screen").classList.add("hidden");
            document.getElementById("start-screen").classList.remove("hidden");
        }
    </script>
</body>
</html>
